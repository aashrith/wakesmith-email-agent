{
  "name": "wakesmith-email-agent",
  "version": "1.0.0",
  "description": "Email Wake-Up Agent — MarseerAI take-home assignment",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "poll": "tsx src/adapters/inbound/poller.ts",
    "cli": "tsx src/adapters/inbound/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "transcripts": "tsx scripts/generateSampleTranscripts.ts"
  },
  "dependencies": {
    "@elysiajs/node": "^1.1.1",
    "@sinclair/typebox": "^0.34.15",
    "elysia": "^1.1.26",
    "js-yaml": "^4.1.0",
    "mailparser": "^3.7.1",
    "nodemailer": "^6.9.16",
    "imapflow": "^1.0.180",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
